<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Độ Nhạy Pro - Game Booster</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        /* ----- RESET & BASE ----- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Rajdhani', 'Segoe UI', sans-serif;
            background: #0a0a12;
            color: #fff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 12px;
            background-image: radial-gradient(ellipse at 20% 50%, rgba(0, 255, 200, 0.06) 0%, transparent 60%),
                              radial-gradient(ellipse at 80% 50%, rgba(255, 0, 200, 0.06) 0%, transparent 60%);
        }

        /* ----- APP CONTAINER ----- */
        #app {
            max-width: 460px;
            width: 100%;
            background: rgba(16, 20, 35, 0.88);
            backdrop-filter: blur(18px);
            border-radius: 36px;
            padding: 18px 16px 28px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.8), 0 0 0 1px rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        #app::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: conic-gradient(from 0deg, rgba(0, 255, 200, 0.03), rgba(255, 0, 200, 0.03), rgba(0, 255, 200, 0.03));
            animation: rotateBg 20s linear infinite;
            pointer-events: none;
        }
        @keyframes rotateBg {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* ----- KEY SCREEN ----- */
        #key-screen {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 20px 0;
        }
        #key-screen .logo {
            font-family: 'Orbitron', monospace;
            font-size: 2.2rem;
            font-weight: 900;
            background: linear-gradient(45deg, #00f5a0, #00d9f5, #ff00e4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 30px rgba(0, 245, 160, 0.3);
            margin-bottom: 6px;
        }
        #key-screen .sub {
            color: #8892b0;
            font-size: 0.9rem;
            letter-spacing: 2px;
            margin-bottom: 20px;
        }
        .key-input-group {
            display: flex;
            gap: 10px;
            background: rgba(255, 255, 255, 0.03);
            padding: 4px;
            border-radius: 60px;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }
        .key-input-group input {
            flex: 1;
            padding: 14px 20px;
            background: transparent;
            border: none;
            color: #fff;
            font-size: 1rem;
            font-family: 'Rajdhani', sans-serif;
            letter-spacing: 1px;
            outline: none;
        }
        .key-input-group input::placeholder {
            color: #4a5070;
        }
        .key-input-group button {
            padding: 12px 28px;
            border: none;
            border-radius: 60px;
            background: linear-gradient(135deg, #00f5a0, #00d9f5);
            color: #0a0a12;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 4px 20px rgba(0, 245, 160, 0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .key-input-group button:hover {
            transform: scale(1.04);
            box-shadow: 0 6px 30px rgba(0, 245, 160, 0.5);
        }
        #key-message {
            margin-top: 14px;
            font-size: 0.9rem;
            min-height: 28px;
            color: #ff6b6b;
        }
        #key-message.success {
            color: #00f5a0;
        }
        .key-hint {
            margin-top: 10px;
            font-size: 0.75rem;
            color: #4a5070;
        }
        .key-hint span {
            color: #00d9f5;
            font-weight: 600;
        }
        .timer-box {
            margin-top: 18px;
            background: rgba(255, 255, 255, 0.02);
            padding: 12px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }
        .timer-box .label {
            font-size: 0.7rem;
            color: #4a5070;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .timer-box .time {
            font-family: 'Orbitron', monospace;
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(90deg, #00f5a0, #00d9f5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* ----- MAIN SCREEN ----- */
        #main-screen {
            position: relative;
            z-index: 2;
            display: none;
            animation: fadeUp 0.5s ease;
        }
        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        /* Header */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }
        .main-header .brand {
            font-family: 'Orbitron', monospace;
            font-size: 1.4rem;
            font-weight: 700;
            background: linear-gradient(135deg, #00f5a0, #00d9f5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .main-header .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.8rem;
            color: #8892b0;
        }
        .main-header .user-info i {
            color: #00f5a0;
        }
        .main-header .user-info .key-status {
            background: rgba(0, 245, 160, 0.12);
            padding: 4px 12px;
            border-radius: 30px;
            color: #00f5a0;
            font-weight: 600;
            font-size: 0.7rem;
        }

        /* Tab Navigation */
        .tab-nav {
            display: flex;
            gap: 6px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 60px;
            padding: 4px;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }
        .tab-nav button {
            flex: 1;
            padding: 10px 0;
            border: none;
            background: transparent;
            color: #4a5070;
            border-radius: 40px;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 600;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            cursor: pointer;
            transition: 0.3s;
        }
        .tab-nav button i {
            font-size: 1.1rem;
        }
        .tab-nav button.active {
            background: linear-gradient(135deg, #00f5a0, #00d9f5);
            color: #0a0a12;
            box-shadow: 0 4px 15px rgba(0, 245, 160, 0.25);
        }
        .tab-content {
            display: none;
            animation: fadeUp 0.3s ease;
        }
        .tab-content.active {
            display: block;
        }

        /* ----- TAB FIX LAG ----- */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 10px;
            margin-bottom: 16px;
        }
        .stat-item {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 16px;
            padding: 12px 8px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }
        .stat-item i {
            font-size: 1.4rem;
            color: #00d9f5;
            margin-bottom: 4px;
            display: block;
        }
        .stat-item .label {
            font-size: 0.6rem;
            color: #4a5070;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .stat-item .value {
            font-family: 'Orbitron', monospace;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            margin-top: 2px;
        }
        .stat-item .value.highlight {
            color: #00f5a0;
        }

        .boost-btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 60px;
            background: linear-gradient(135deg, #ff00e4, #ff6b6b);
            color: #fff;
            font-family: 'Orbitron', monospace;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 6px 30px rgba(255, 0, 228, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        .boost-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 8px 40px rgba(255, 0, 228, 0.5);
        }
        .boost-progress {
            margin-top: 14px;
            display: none;
        }
        .boost-progress .bar {
            height: 8px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 10px;
            overflow: hidden;
        }
        .boost-progress .bar div {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #00f5a0, #00d9f5);
            border-radius: 10px;
            transition: width 0.4s ease;
        }
        .boost-progress .label {
            font-size: 0.8rem;
            color: #8892b0;
            margin-top: 6px;
            text-align: center;
        }

        /* ----- TAB SENSITIVITY ----- */
        .device-input {
            display: flex;
            gap: 10px;
            margin-bottom: 18px;
        }
        .device-input input {
