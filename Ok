function showToast(msg, dur = 2500) {
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toast._timer);
    toast._timer = setTimeout(() => toast.classList.remove('show'), dur);
}

// ============================================================
//  KEY MANAGEMENT
// ============================================================
function isKeyValid(key) {
    return VALID_KEYS.includes(key);
}

function checkKeyActivation() {
    if (!currentKey || !keyActivatedAt) return false;
    const elapsed = (Date.now() - keyActivatedAt) / (1000 * 60 * 60); // giờ
    if (elapsed >= KEY_DURATION_HOURS) {
        // Hết hạn
        localStorage.removeItem('fixlag_key');
        localStorage.removeItem('fixlag_key_activated');
        currentKey = null;
        keyActivatedAt = null;
        return false;
    }
    return true;
}

function activateKey(key) {
    if (!isKeyValid(key)) {
        keyMessage.textContent = '❌ Key không hợp lệ!';
        keyMessage.className = '';
        showToast('Key sai!', 2000);
        return false;
    }
    // Lưu key
    currentKey = key;
    keyActivatedAt = Date.now();
    localStorage.setItem('fixlag_key', key);
    localStorage.setItem('fixlag_key_activated', String(keyActivatedAt));
    keyMessage.textContent = '✅ Kích hoạt thành công!';
    keyMessage.className = 'success';
    showToast('🎮 Key hợp lệ! Chào mừng bạn!', 3000);
    enterMainApp();
    return true;
}

function enterMainApp() {
    isActivated = true;
    keyScreen.style.display = 'none';
    mainScreen.style.display = 'block';
    keyStatus.textContent = 'Đã kích hoạt';
    startCountdown();
    loadSensitivityData();
    renderDeviceList();
    startStatsSimulation();
}

function startCountdown() {
    if (!keyActivatedAt) return;
    timerBox.style.display = 'block';
    if (timerInterval) clearInterval(timerInterval);
    timerInterval = setInterval(() => {
        const elapsed = (Date.now() - keyActivatedAt) / 1000; // giây
        const remaining = Math.max(0, KEY_DURATION_HOURS * 3600 - elapsed);
        if (remaining <= 0) {
            clearInterval(timerInterval);
            countdownDisplay.textContent = '00:00:00';
            showToast('⏰ Key đã hết hạn! Vui lòng nhập key mới.', 4000);
            // Thoát ra màn hình key
            localStorage.removeItem('fixlag_key');
            localStorage.removeItem('fixlag_key_activated');
            currentKey = null;
            keyActivatedAt = null;
            isActivated = false;
            keyScreen.style.display = 'block';
            mainScreen.style.display = 'none';
            timerBox.style.display = 'none';
            keyMessage.textContent = '⏰ Key đã hết hạn. Nhập key mới.';
            keyMessage.className = '';
            return;
        }
        const hours = Math.floor(remaining / 3600);
        const mins = Math.floor((remaining % 3600) / 60);
        const secs = Math.floor(remaining % 60);
        countdownDisplay.textContent =
            String(hours).padStart(2, '0') + ':' +
            String(mins).padStart(2, '0') + ':' +
            String(secs).padStart(2, '0');
    }, 1000);
}

