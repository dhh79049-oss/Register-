        sensScope.value = 30;
        sensXVal.textContent = '50';
        sensYVal.textContent = '50';
        sensADSVal.textContent = '45';
        sensScopeVal.textContent = '30';
        showToast(`🆕 Thiết bị mới, cài đặt mặc định`, 2000);
    }
    deviceInput.value = deviceName;
}

function renderDeviceList() {
    const devices = Object.keys(sensData);
    if (devices.length === 0) {
        deviceList.innerHTML = '<span style="color:#4a5070;font-size:0.8rem;">Chưa có thiết bị nào</span>';
        return;
    }
    deviceList.innerHTML = devices.map(d =>
        `<span class="device-chip" data-device="${d}">${d}</span>`
    ).join('');
    // Gắn sự kiện click để tải
    document.querySelectorAll('.device-chip').forEach(el => {
        el.addEventListener('click', () => {
            const device = el.dataset.device;
            loadDevice(device);
        });
    });
}

// Lưu cài đặt cho thiết bị hiện tại
saveSensBtn.addEventListener('click', () => {
    if (!isActivated) {
        showToast('🔑 Vui lòng kích hoạt key!');
        return;
    }
    const device = deviceInput.value.trim();
    if (!device) {
        showToast('⚠️ Vui lòng nhập tên thiết bị!', 2000);
        return;
    }
    sensData[device] = {
        x: parseInt(sensX.value),
        y: parseInt(sensY.value),
        ads: parseInt(sensADS.value),
        scope: parseInt(sensScope.value)
    };
    saveSensitivityData();
    renderDeviceList();
    showToast(`✅ Đã lưu cài đặt cho ${device}`, 2500);
});

// Tải thiết bị khi nhấn nút tìm kiếm
loadDeviceBtn.addEventListener('click', () => {
    const device = deviceInput.value.trim();
    if (device) {
        loadDevice(device);
    } else {
        showToast('⚠️ Nhập tên thiết bị trước', 1500);
    }
});

// Cũng cho phép Enter
deviceInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') loadDeviceBtn.click();
});

// ============================================================
//  TAB SWITCHING
// ============================================================
document.querySelectorAll('.tab-nav button').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-nav button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.tab-content').forEach(tc => tc.classList.remove('active'));
        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    });
});

// ============================================================
//  KEY ACTIVATION EVENT
// ============================================================
activateBtn.addEventListener('click', () => {
    const key = keyInput.value.trim().toUpperCase();
    if (key) {
        activateKey(key);
    } else {
        keyMessage.textContent = '⚠️ Vui lòng nhập key.';
        keyMessage.className = '';
    }
});
keyInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') activateBtn.click();
});

// ============================================================
//  INIT – Kiểm tra key khi load
// ============================================================
(function init() {
    const hasValid = checkKeyActivation();
    if (hasValid && currentKey) {
        // Tự động kích hoạt
        keyMessage.textContent = '✅ Key hợp lệ! Đang vào ứng dụng...';
        keyMessage.className = 'success';
        setTimeout(() => {
            enterMainApp();
        }, 400);
    } else {
        // Chưa có key hoặc hết hạn
        keyScreen.style.display = 'block';
        mainScreen.style.display = 'none';
        if (currentKey) {
            keyMessage.textContent = '⏰ Key đã hết hạn. Vui lòng nhập key mới.';
            keyMessage.className = '';
            localStorage.removeItem('fixlag_key');
            localStorage.removeItem('fixlag_key_activated');
            currentKey = null;
            keyActivatedAt = null;
        }
    }
})();

// ============================================================
//  CLEANUP
// ============================================================
window.addEventListener('beforeunload', () => {
    if (timerInterval) clearInterval(timerInterval);
    if (statsInterval) clearInterval(statsInterval);
});

console.log('⚡ Độ Nhạy Pro - Game Booster');
console.log('🔑 10 key hợp lệ:', VALID_KEYS.join(', '));
    </script>
