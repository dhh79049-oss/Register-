            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 30px;
            color: #fff;
            font-size: 0.95rem;
            outline: none;
            font-family: 'Rajdhani', sans-serif;
        }
        .device-input input::placeholder {
            color: #4a5070;
        }
        .device-input button {
            padding: 12px 24px;
            border: none;
            border-radius: 30px;
            background: linear-gradient(135deg, #00f5a0, #00d9f5);
            color: #0a0a12;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }
        .device-input button:hover {
            transform: scale(1.04);
        }

        .sens-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }
        .sens-item .label {
            font-weight: 600;
            font-size: 0.95rem;
            width: 70px;
        }
        .sens-item .range-wrap {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .sens-item input[type="range"] {
            flex: 1;
            -webkit-appearance: none;
            appearance: none;
            height: 4px;
            background: #2a2f4a;
            border-radius: 4px;
            outline: none;
        }
        .sens-item input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: linear-gradient(135deg, #00f5a0, #00d9f5);
            cursor: pointer;
            box-shadow: 0 0 20px rgba(0, 245, 160, 0.3);
        }
        .sens-item .val {
            font-family: 'Orbitron', monospace;
            font-size: 0.9rem;
            min-width: 36px;
            text-align: right;
            color: #00d9f5;
        }

        .save-sens-btn {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 60px;
            background: linear-gradient(135deg, #ff00e4, #ff6b6b);
            color: #fff;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 12px;
            box-shadow: 0 4px 20px rgba(255, 0, 228, 0.25);
        }
        .save-sens-btn:hover {
            transform: scale(1.02);
        }

        .saved-devices {
            margin-top: 16px;
            padding: 12px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }
        .saved-devices .title {
            font-size: 0.75rem;
            color: #4a5070;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        .device-chip {
            display: inline-block;
            background: rgba(0, 245, 160, 0.1);
            padding: 4px 16px;
            border-radius: 30px;
            font-size: 0.8rem;
            color: #00f5a0;
            margin: 4px 6px 4px 0;
            border: 1px solid rgba(0, 245, 160, 0.15);
        }

        /* ----- TOAST ----- */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #1a1e30;
            padding: 12px 24px;
            border-radius: 60px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(12px);
            font-size: 0.9rem;
            color: #fff;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            opacity: 0;
            transition: 0.4s;
            pointer-events: none;
            z-index: 999;
            font-family: 'Rajdhani', sans-serif;
        }
        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* ----- RESPONSIVE ----- */
        @media (max-width: 420px) {
            #app { padding: 12px; }
            .stats-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
            .tab-nav button { font-size: 0.75rem; padding: 8px 0; }
            .tab-nav button i { font-size: 0.9rem; }
            .key-input-group input { font-size: 0.85rem; padding: 12px 16px; }
            .key-input-group button { padding: 10px 18px; font-size: 0.85rem; }
            .main-header .brand { font-size: 1.2rem; }
        }
    </style>
</head>
