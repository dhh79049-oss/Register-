    const temp = Math.floor(Math.random() * 12) + 32;
    const ping = Math.floor(Math.random() * 20) + 10;
    const fps = Math.floor(Math.random() * 30) + 50;

    cpuVal.textContent = cpu + '%';
    ramVal.textContent = ram + '%';
    batteryVal.textContent = battery + '%';
    tempVal.textContent = temp + '°C';
    pingVal.textContent = ping + 'ms';
    fpsVal.textContent = fps;
}

let statsInterval = null;
function startStatsSimulation() {
    if (statsInterval) clearInterval(statsInterval);
    updateStats();
    statsInterval = setInterval(updateStats, 2000);
}

